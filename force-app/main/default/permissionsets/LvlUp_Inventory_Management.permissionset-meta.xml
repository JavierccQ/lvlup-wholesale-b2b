<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>LvlUp Inventory Management</label>
    <description>Grants field-level access to the custom inventory and purchase-rule fields on Product2 used by the Contextual Quick Buy feature.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <fieldPermissions>
        <editable>true</editable>
        <field>Product2.Inventory_Quantity__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Product2.Min_Order_Quantity__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Product2.Order_Increment__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Product2.Max_Order_Quantity__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
