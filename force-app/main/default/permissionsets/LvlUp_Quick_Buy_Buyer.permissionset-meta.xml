<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>LvlUp Quick Buy Buyer</label>
    <description>Grants storefront buyers access to the Contextual Quick Buy Apex controller and read access to the Product2 inventory/purchase-rule fields.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>LvlupQuickBuyController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <fieldPermissions>
        <editable>false</editable>
        <field>Product2.Inventory_Quantity__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Product2.Min_Order_Quantity__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Product2.Order_Increment__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Product2.Max_Order_Quantity__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
